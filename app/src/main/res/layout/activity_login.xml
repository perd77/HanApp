<?xml version="1.0" encoding="utf-8"?>
<!-- Login screen: sky-blue branded top, a single name field, and a continue button.
     Kept intentionally minimal so the entry point feels calm and uncluttered. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white_surface"
    android:padding="28dp">

    <!-- App wordmark, using the Chango display font, as the visual anchor. -->
    <TextView
        android:id="@+id/textLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/sky_blue"
        android:textSize="48sp"
        android:letterSpacing="0.01"
        app:fontFamily="@font/chango_regular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/textTagline"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Short subtitle explaining the app in one line. -->
    <TextView
        android:id="@+id/textTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="40dp"
        android:text="@string/login_tagline"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/inter_regular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textLogo"
        app:layout_constraintBottom_toTopOf="@id/inputLayoutName" />

    <!-- Material text field wrapper: provides the floating label, helper/error text,
         and rounded outline styling for the name input. -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutName"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/login_name_hint"
        app:boxStrokeColor="@color/sky_blue"
        app:hintTextColor="@color/sky_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textTagline"
        app:layout_constraintBottom_toTopOf="@id/buttonContinue"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- The actual editable field. inputType=textPersonName gives the right keyboard;
             maxLines=1 + imeOptions=actionDone keeps it a single-line entry. -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_regular"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:imeOptions="actionDone" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Primary action: validates the name, then proceeds into the app. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonContinue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="@string/login_continue"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:fontFamily="@font/inter_semibold"
        app:backgroundTint="@color/sky_blue"
        app:cornerRadius="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputLayoutName" />

</androidx.constraintlayout.widget.ConstraintLayout>