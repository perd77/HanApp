<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:padding="16dp">

    <TextView
        android:id="@+id/textClaimItemName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:fontFamily="@font/inter_semibold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Blue Backpack" />

    <TextView
        android:id="@+id/textClaimantInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="@font/inter_regular"
        app:layout_constraintTop_toBottomOf="@id/textClaimItemName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Claimed by Curson · 09171234567" />

    <TextView
        android:id="@+id/textClaimProof"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="@font/inter_regular"
        app:layout_constraintTop_toBottomOf="@id/textClaimantInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="It's my backpack, has my name tag inside."/>

    <TextView
        android:id="@+id/textClaimTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:fontFamily="@font/inter_regular"
        app:layout_constraintTop_toBottomOf="@id/textClaimProof"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="1h ago" />

    <!-- Action row: only visible while the claim is PENDING. -->
    <LinearLayout
        android:id="@+id/layoutClaimActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/textClaimTimestamp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonReject"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/notification_reject"
            android:textAllCaps="false"
            app:strokeColor="@color/status_claimed"
            android:textColor="@color/status_claimed" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonApprove"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/notification_approve"
            android:textAllCaps="false"
            app:backgroundTint="@color/sky_blue" />
    </LinearLayout>

    <!-- Read-only status label: shown instead of the action row once resolved. -->
    <TextView
        android:id="@+id/textClaimResolvedStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_badge_claimed"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="12sp"
        android:fontFamily="@font/inter_medium"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/textClaimTimestamp"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Approved" />
</androidx.constraintlayout.widget.ConstraintLayout>