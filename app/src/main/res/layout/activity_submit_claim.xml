<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white_surface"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/buttonClaimClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/post_close_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textClaimTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:fontFamily="@font/inter_semibold"
        app:layout_constraintTop_toBottomOf="@id/buttonClaimClose"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Claim This Item" />

    <TextView
        android:id="@+id/textClaimSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="@font/inter_regular"
        app:layout_constraintTop_toBottomOf="@id/textClaimTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Let the poster know this is yours." />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutContact"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:hint="@string/claim_contact_hint"
        app:boxStrokeColor="@color/sky_blue"
        app:hintTextColor="@color/sky_blue"
        app:layout_constraintTop_toBottomOf="@id/textClaimSubtitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:maxLength="11"
            android:maxLines="1"
            android:fontFamily="@font/inter_regular" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutProof"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/claim_proof_hint"
        app:boxStrokeColor="@color/sky_blue"
        app:hintTextColor="@color/sky_blue"
        app:layout_constraintTop_toBottomOf="@id/inputLayoutContact">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextProof"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top"
            android:fontFamily="@font/inter_regular" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSubmitClaim"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="@string/claim_submit_button"
        android:textAllCaps="false"
        android:fontFamily="@font/inter_semibold"
        app:backgroundTint="@color/sky_blue"
        app:cornerRadius="14dp"
        app:layout_constraintTop_toBottomOf="@id/inputLayoutProof" />

    <ProgressBar
        android:id="@+id/progressClaimSubmit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/buttonSubmitClaim"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>