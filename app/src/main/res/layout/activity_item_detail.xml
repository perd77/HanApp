<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white_surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Large photo at the top; placeholder color shows if no photo exists. -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageDetailPhoto"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@color/sky_blue_light"
            android:scaleType="centerCrop"
            android:contentDescription="@string/item_photo_description"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Close button floats over the photo, top-start corner. -->
        <ImageButton
            android:id="@+id/buttonDetailClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="12dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_remove_photo_circle"
            android:contentDescription="@string/post_close_description"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Status badge floats over the photo, top-end corner. -->
        <TextView
            android:id="@+id/badgeDetailStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@drawable/bg_badge_unclaimed"
            android:fontFamily="@font/inter_medium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:textColor="@color/status_unclaimed"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Unclaimed" />

        <!-- Content block below the photo -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/imageDetailPhoto">

            <TextView
                android:id="@+id/textDetailName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/inter_semibold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Blue Backpack" />

            <!-- Category + location tags, same visual language as the feed cards. -->
            <TextView
                android:id="@+id/tagDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_tag_neutral"
                android:fontFamily="@font/inter_medium"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/sky_blue_dark"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/textDetailName"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="Bag" />

            <TextView
                android:id="@+id/tagDetailLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tag_neutral"
                android:fontFamily="@font/inter_medium"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/sky_blue_dark"
                android:textSize="12sp"
                app:layout_constraintTop_toTopOf="@id/tagDetailCategory"
                app:layout_constraintBottom_toBottomOf="@id/tagDetailCategory"
                app:layout_constraintStart_toEndOf="@id/tagDetailCategory"
                tools:text="Library" />

            <TextView
                android:id="@+id/textDetailDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                android:fontFamily="@font/inter_regular"
                app:layout_constraintTop_toBottomOf="@id/tagDetailCategory"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Found near the library entrance, has a small keychain attached." />

            <!-- Posted-by + timestamp footnote -->
            <TextView
                android:id="@+id/textDetailMeta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"
                app:layout_constraintTop_toBottomOf="@id/textDetailDescription"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Posted by Ray · 2h ago" />

            <!-- Claim button: only shown when the viewer is NOT the poster,
                 and the item is still UNCLAIMED. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClaim"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="@string/detail_claim_button"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_semibold"
                app:backgroundTint="@color/sky_blue"
                app:cornerRadius="14dp"
                app:layout_constraintTop_toBottomOf="@id/textDetailMeta" />

            <!-- Shown instead of the Claim button when the viewer posted this item. -->
            <TextView
                android:id="@+id/textOwnPostNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_tag_neutral"
                android:gravity="center"
                android:padding="14dp"
                android:text="@string/detail_own_post_notice"
                android:textColor="@color/sky_blue_dark"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/textDetailMeta" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>