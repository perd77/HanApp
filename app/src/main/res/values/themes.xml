<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HanApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/sky_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:colorBackground">@color/off_white_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:statusBarColor">@color/sky_blue</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <style name="Theme.HanApp" parent="Base.Theme.HanApp" />

    <!-- System-level splash screen theme. Shown automatically by Android the
         instant the app launches, before LoginActivity finishes its first
         frame — this replaces the default green-robot splash with our own
         branding (sky-blue background + the launcher icon). -->
    <style name="Theme.HanApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sky_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.HanApp</item>
    </style>
</resources>